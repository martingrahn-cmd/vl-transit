# Trafiklab API-nycklar
# Skaffa gratis på https://trafiklab.se

# GTFS Regional Static data (Bronze: 50 req/mån)
TRAFIKLAB_STATIC_KEY=din_static_nyckel_här

# GTFS Regional Realtime (Bronze: 30 000 req/mån)
TRAFIKLAB_REALTIME_KEY=din_realtime_nyckel_här

# Operator (VL = Västmanland Länstrafik)
GTFS_OPERATOR=vastmanland

# Server-port
PORT=3001
